# Alienware RGB mechanical keyboards — vendor HID lighting interface.
# Grants the logged-in desktop user read/write access so k-rgb runs without root.
#
#   AW410K  04f2:1968
#   AW510K  04f2:1830
#
# Install:
#   sudo cp 60-alienware-keyboards.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger --subsystem-match=hidraw
# (or simply replug the keyboard afterwards)

KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="04f2", ATTRS{idProduct}=="1968", MODE="0660", GROUP="plugdev", TAG+="uaccess"
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="04f2", ATTRS{idProduct}=="1830", MODE="0660", GROUP="plugdev", TAG+="uaccess"
